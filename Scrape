<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apex - Finance Dashboard</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React and ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <!-- Babel -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy: '#0f172a',
                        lightbg: '#f8fafc',
                        cardbg: '#ffffff',
                        accent: '#3b82f6',
                        grays: '#64748b'
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body {
            background-color: #f8fafc;
            color: #0f172a;
        }
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9; 
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1; 
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8; 
        }
        
        .draggable-widget {
            cursor: grab;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .draggable-widget:active {
            cursor: grabbing;
        }
        .dragging {
            opacity: 0.5;
            transform: scale(0.98);
        }
        .drag-over {
            border: 2px dashed #3b82f6 !important;
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel" data-presets="es2015,react">
        try {
            const { useState, useEffect, useMemo, useCallback, useRef } = React;

            const INDICES = {
                'DAX': { name: 'DAX', symbol: 'DAX' },
                'DOW': { name: 'Dow Jones', symbol: 'DOW' },
                'SP500': { name: 'S&P 500', symbol: 'SP500' },
                'NIKKEI': { name: 'Nikkei 225', symbol: 'NIKKEI' },
                'MSCI_CHINA': { name: 'MSCI China ETF', symbol: 'MSCI_CHINA' }
            };

            const DATA_URL = "https://raw.githubusercontent.com/kekebw/Apex/main/data/market.json";

            let globalMarketData = null;
            let fetchingPromise = null;

            const getMarketData = async () => {
                if (globalMarketData) return globalMarketData;
                if (fetchingPromise) return fetchingPromise;
                
                fetchingPromise = fetch(DATA_URL, { cache: 'no-cache' })
                    .then(res => {
                        if (!res.ok) throw new Error("Could not load database");
                        return res.json();
                    })
                    .then(data => {
                        globalMarketData = data;
                        return data;
                    });
                return fetchingPromise;
            };

            const fetchYahooData = async (symbol, range) => {
                const data = await getMarketData();
                if (!data || !data.indices || !data.indices[symbol] || !data.indices[symbol][range]) {
                    throw new Error("Data not available");
                }
                const rawSeries = data.indices[symbol][range];
                return rawSeries.map(d => {
                    const dateObj = new Date(d.time * 1000);
                    return {
                        date: ['1M', '1Y'].includes(range) ? dateObj.toISOString().split('T')[0] : dateObj.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}),
                        price: d.price
                    };
                });
            };

            const fetchRealFearGreed = async () => {
                const data = await getMarketData();
                if (data && data.fear_and_greed !== null) {
                    return data.fear_and_greed;
                }
                // Fallback if CNN scraper failed
                console.log("GitHub data missing F&G, falling back to Alternative.me");
                const res = await fetch('https://api.alternative.me/fng/');
                const fallbackData = await res.json();
                return parseInt(fallbackData.data[0].value);
            };

            const DragIcon = () => (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="text-gray-400 hover:text-gray-600">
                    <circle cx="9" cy="12" r="1"></circle><circle cx="9" cy="5" r="1"></circle><circle cx="9" cy="19" r="1"></circle>
                    <circle cx="15" cy="12" r="1"></circle><circle cx="15" cy="5" r="1"></circle><circle cx="15" cy="19" r="1"></circle>
                </svg>
            );

            // --- Components ---

            const Card = ({ title, children, onDragStart, onDragOver, onDrop, onDragEnter, onDragLeave, id }) => (
                <div 
                    className="bg-cardbg rounded-xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] border border-slate-100 p-5 flex flex-col h-full draggable-widget transition-all"
                    draggable="true"
                    onDragStart={onDragStart}
                    onDragOver={onDragOver}
                    onDragEnter={onDragEnter}
                    onDragLeave={onDragLeave}
                    onDrop={onDrop}
                    data-id={id}
                >
                    <div className="flex justify-between items-center mb-4 cursor-grab active:cursor-grabbing">
                        <h3 className="font-semibold text-navy text-lg">{title}</h3>
                        <div className="p-1 cursor-grab" title="Drag to reorder">
                            <DragIcon />
                        </div>
                    </div>
                    <div className="flex-1 min-h-[250px]">
                        {children}
                    </div>
                </div>
            );

            const MarketChart = ({ dataKey }) => {
                const [range, setRange] = useState('1M');
                const [chartData, setChartData] = useState([]);
                const [loading, setLoading] = useState(true);
                const [error, setError] = useState(null);
                const [currentPriceMap, setCurrentPriceMap] = useState({});
                const [priceFallback, setPriceFallback] = useState(null);

                const canvasRef = useRef(null);
                const chartRef = useRef(null);
                
                const meta = INDICES[dataKey];
                const ranges = ['1D', '1W', '1M', '1Y'];

                useEffect(() => {
                    let isMounted = true;
                    setLoading(true);
                    setError(null);
                    
                    fetchYahooData(meta.symbol, range)
                        .then(data => {
                            if (!isMounted) return;
                            if (data.length === 0) throw new Error("No data returned");
                            setChartData(data);
                            setPriceFallback(data[data.length-1].price);
                            setLoading(false);

                            // Dispatch global event for portfolio updates
                            const priceEvent = new CustomEvent('apexPriceUpdate', { 
                                detail: { symbol: dataKey, currentPrice: data[data.length-1].price } 
                            });
                            window.dispatchEvent(priceEvent);
                        })
                        .catch(err => {
                            if (!isMounted) return;
                            console.error(err);
                            setError("Error fetching live data (CORS or Rate Limit). Please try again later.");
                            setLoading(false);
                        });

                    return () => { isMounted = false; };
                }, [range, meta.symbol]);

                useEffect(() => {
                    if (chartRef.current) chartRef.current.destroy();
                    if (!chartData || chartData.length === 0 || loading) return;

                    const startPrice = chartData[0].price;
                    const endPrice = chartData[chartData.length - 1].price;
                    const isPositive = endPrice >= startPrice;
                    const color = isPositive ? '#10b981' : '#f43f5e';

                    if (canvasRef.current) {
                        const ctx = canvasRef.current.getContext('2d');
                        chartRef.current = new Chart(ctx, {
                            type: 'line',
                            data: {
                                labels: chartData.map(d => d.date),
                                datasets: [{
                                    data: chartData.map(d => d.price),
                                    borderColor: color,
                                    borderWidth: 2,
                                    pointRadius: 0,
                                    pointHoverRadius: 4,
                                    fill: false,
                                    tension: 0.1
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { display: false },
                                    tooltip: {
                                        mode: 'index',
                                        intersect: false,
                                        callbacks: { label: (c) => c.parsed.y.toLocaleString() }
                                    }
                                },
                                scales: {
                                    x: {
                                        display: true,
                                        grid: { display: false },
                                        ticks: { maxTicksLimit: 5, color: '#64748b', font: { size: 10 } }
                                    },
                                    y: {
                                        display: true,
                                        position: 'right',
                                        grid: { color: '#f1f5f9' },
                                        ticks: { color: '#64748b', font: { size: 10 }, callback: (v) => v.toLocaleString() }
                                    }
                                }
                            }
                        });
                    }

                    return () => {
                        if (chartRef.current) chartRef.current.destroy();
                    };
                }, [chartData, loading]);

                let diff = 0, diffPercent = 0, startPrice = 0, endPrice = 0, isPositive = true;
                if (chartData.length > 0) {
                    startPrice = chartData[0].price;
                    endPrice = chartData[chartData.length - 1].price;
                    diff = endPrice - startPrice;
                    diffPercent = (diff / startPrice) * 100;
                    isPositive = diff >= 0;
                }

                return (
                    <div className="flex flex-col h-full">
                        <div className="flex justify-between items-end mb-4 h-[42px]">
                            <div>
                                {loading && !priceFallback ? (
                                    <div className="text-sm text-slate-400 animate-pulse">Loading API Data...</div>
                                ) : error && !priceFallback ? (
                                    <div className="text-xs text-rose-500 max-w-[120px] leading-tight">{error}</div>
                                ) : (
                                    <>
                                        <div className="text-2xl font-bold text-navy">{(endPrice || priceFallback).toLocaleString('de-DE', { minimumFractionDigits: 2 })}</div>
                                        <div className={`text-sm font-medium ${isPositive ? 'text-emerald-500' : 'text-rose-500'}`}>
                                            {isPositive ? '+' : ''}{diff.toFixed(2)} ({isPositive ? '+' : ''}{diffPercent.toFixed(2)}%)
                                        </div>
                                    </>
                                )}
                            </div>
                            <div className="flex space-x-1 bg-slate-100 p-1 rounded-lg">
                                {ranges.map(r => (
                                    <button 
                                        key={r}
                                        onClick={() => setRange(r)}
                                        className={`px-3 py-1 text-xs font-medium rounded-md transition-colors ${range === r ? 'bg-white shadow-sm text-navy' : 'text-slate-500 hover:text-navy'}`}
                                    >
                                        {r}
                                    </button>
                                ))}
                            </div>
                        </div>
                        <div className="flex-1 w-full relative flex items-center justify-center bg-slate-50/50 rounded-lg" style={{ minHeight: '200px' }}>
                            {loading && <div className="absolute inset-0 flex items-center justify-center bg-white/50 backdrop-blur-[1px] text-sm text-slate-500 z-10 animate-pulse">Fetching Real Live Data...</div>}
                            <canvas ref={canvasRef}></canvas>
                        </div>
                    </div>
                );
            };

            const FearGreedWidget = () => {
                const [value, setValue] = useState(50);
                const [loading, setLoading] = useState(true);
                const canvasRef = useRef(null);
                const chartRef = useRef(null);
                
                useEffect(() => {
                    let isMounted = true;
                    fetchRealFearGreed().then(val => {
                        if (isMounted) {
                            setValue(val);
                            setLoading(false);
                        }
                    }).catch(e => {
                        if (isMounted) setLoading(false);
                    });
                    return () => isMounted = false;
                }, []);

                let status = '';
                if (value <= 25) status = 'Extreme Fear';
                else if (value <= 50) status = 'Fear';
                else if (value <= 75) status = 'Neutral';
                else status = 'Greed';

                useEffect(() => {
                    if (chartRef.current) chartRef.current.destroy();
                    if (!canvasRef.current) return;

                    const ctx = canvasRef.current.getContext('2d');
                    chartRef.current = new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Extreme Fear', 'Fear', 'Neutral', 'Greed'],
                            datasets: [{
                                data: [25, 25, 25, 25],
                                backgroundColor: ['#f43f5e', '#fb923c', '#fbbf24', '#34d399'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            circumference: 180,
                            rotation: -90,
                            cutout: '70%',
                            plugins: {
                                legend: { display: false },
                                tooltip: { enabled: false }
                            }
                        }
                    });

                    return () => { if (chartRef.current) chartRef.current.destroy(); };
                }, []);

                const needleAngle = 180 - (value / 100) * 180;
                const rad = Math.PI / 180;
                const nx = 150 + 80 * Math.cos(needleAngle * rad);
                const ny = 140 - 80 * Math.sin(needleAngle * rad);

                return (
                    <div className="flex flex-col items-center justify-center h-full relative pt-4">
                        {loading && <div className="absolute top-2 left-2 text-xs text-slate-400 animate-pulse">Live Syncing...</div>}
                        <div style={{ width: '100%', height: '180px', position: 'relative' }}>
                            <canvas ref={canvasRef}></canvas>
                            {/* Needle Overlay */}
                            <svg className="absolute top-0 left-0 w-full h-full pointer-events-none transition-all duration-1000 ease-in-out" viewBox="0 0 300 180" preserveAspectRatio="xMidYMid meet">
                                <circle cx="150" cy="140" r="6" fill="#0f172a" />
                                <line x1="150" y1="140" x2={nx} y2={ny} stroke="#0f172a" strokeWidth="3" strokeLinecap="round" />
                            </svg>
                        </div>
                        <div className="text-center mt-[-20px]">
                            <div className="text-4xl font-bold text-navy">{value}</div>
                            <div className="text-sm font-semibold text-slate-500 uppercase tracking-widest mt-1">{status}</div>
                        </div>
                    </div>
                );
            };

            const PortfolioWidget = () => {
                const [positions, setPositions] = useState([]);
                const [symbol, setSymbol] = useState('DAX');
                const [price, setPrice] = useState('');
                const [amount, setAmount] = useState('');
                const [globalPrices, setGlobalPrices] = useState({});

                useEffect(() => {
                    const saved = localStorage.getItem('apex_portfolio_real');
                    if (saved) {
                        try { setPositions(JSON.parse(saved)); } catch (e) {}
                    }

                    const handlePriceUpdate = (e) => {
                        setGlobalPrices(prev => ({ ...prev, [e.detail.symbol]: e.detail.currentPrice }));
                    };
                    window.addEventListener('apexPriceUpdate', handlePriceUpdate);
                    return () => window.removeEventListener('apexPriceUpdate', handlePriceUpdate);
                }, []);

                const savePositions = (newPos) => {
                    setPositions(newPos);
                    localStorage.setItem('apex_portfolio_real', JSON.stringify(newPos));
                };

                const handleAdd = (e) => {
                    e.preventDefault();
                    if (!price || !amount) return;
                    const newPos = {
                        id: Date.now(),
                        symbol,
                        buyPrice: parseFloat(price),
                        amount: parseFloat(amount)
                    };
                    savePositions([...positions, newPos]);
                    setPrice('');
                    setAmount('');
                };

                const handleRemove = (id) => {
                    savePositions(positions.filter(p => p.id !== id));
                };

                const calculatePnL = (pos) => {
                    const currentPrice = globalPrices[pos.symbol] || pos.buyPrice;
                    const valueNow = currentPrice * pos.amount;
                    const valueBuy = pos.buyPrice * pos.amount;
                    const pnl = valueNow - valueBuy;
                    const pnlPercent = valueBuy > 0 ? (pnl / valueBuy) * 100 : 0;
                    return { currentPrice, valueNow, pnl, pnlPercent };
                };

                let totalValue = 0;
                let totalBuy = 0;

                const rows = positions.map(pos => {
                    const metrics = calculatePnL(pos);
                    totalValue += metrics.valueNow;
                    totalBuy += pos.buyPrice * pos.amount;
                    return { ...pos, ...metrics };
                });

                const totalPnL = totalValue - totalBuy;
                const totalPnLPercent = totalBuy ? (totalPnL / totalBuy) * 100 : 0;

                return (
                    <div className="flex flex-col h-full overflow-hidden">
                        <div className="bg-slate-50 p-4 rounded-lg mb-4 flex justify-between items-center">
                            <div>
                                <div className="text-xs text-slate-500 uppercase tracking-wider font-semibold">Total Value</div>
                                <div className="text-xl font-bold text-navy">{totalValue.toLocaleString('de-DE', { style: 'currency', currency: 'EUR' })}</div>
                            </div>
                            <div className="text-right">
                                <div className="text-xs text-slate-500 uppercase tracking-wider font-semibold">Total PnL</div>
                                <div className={`text-lg font-bold ${totalPnL >= 0 ? 'text-emerald-500' : 'text-rose-500'}`}>
                                    {totalPnL >= 0 ? '+' : ''}{totalPnL.toLocaleString('de-DE', { style: 'currency', currency: 'EUR' })}
                                </div>
                            </div>
                        </div>

                        <div className="flex-1 overflow-auto rounded-lg border border-slate-100 min-h-[150px]">
                            <table className="w-full text-sm text-left">
                                <thead className="text-xs text-slate-500 bg-slate-50 uppercase border-b border-slate-100 sticky top-0">
                                    <tr>
                                        <th className="px-3 py-2">Asset</th>
                                        <th className="px-3 py-2">Amt</th>
                                        <th className="px-3 py-2 text-right">PnL</th>
                                        <th className="px-3 py-2 text-center">Act</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {rows.length === 0 ? (
                                        <tr><td colSpan="4" className="px-3 py-6 text-center text-slate-400">No positions. Add one below.</td></tr>
                                    ) : rows.map(r => (
                                        <tr key={r.id} className="border-b border-slate-50 hover:bg-slate-50/50">
                                            <td className="px-3 py-2 font-medium text-navy">{INDICES[r.symbol]?.name || r.symbol}</td>
                                            <td className="px-3 py-2">{r.amount}</td>
                                            <td className={`px-3 py-2 text-right ${r.pnl >= 0 ? 'text-emerald-500' : 'text-rose-500'}`}>
                                                {r.pnlPercent >= 0 ? '+' : ''}{r.pnlPercent.toFixed(1)}%
                                            </td>
                                            <td className="px-3 py-2 text-center">
                                                <button onClick={() => handleRemove(r.id)} className="text-slate-400 hover:text-rose-500">×</button>
                                            </td>
                                        </tr>
                                    ))}
                                </tbody>
                            </table>
                        </div>

                        <form onSubmit={handleAdd} className="mt-4 flex gap-2">
                            <select 
                                value={symbol} onChange={e => setSymbol(e.target.value)}
                                className="bg-slate-50 border border-slate-200 text-sm rounded-md px-2 py-1.5 focus:outline-none focus:ring-1 focus:ring-accent flex-1"
                            >
                                {Object.keys(INDICES).map(k => <option key={k} value={k}>{INDICES[k].name}</option>)}
                            </select>
                            <input 
                                type="number" placeholder="Price" value={price} onChange={e => setPrice(e.target.value)} step="0.01" required
                                className="bg-slate-50 border border-slate-200 text-sm rounded-md px-2 py-1.5 w-20 focus:outline-none focus:ring-1 focus:ring-accent"
                            />
                            <input 
                                type="number" placeholder="Amt" value={amount} onChange={e => setAmount(e.target.value)} step="any" required
                                className="bg-slate-50 border border-slate-200 text-sm rounded-md px-2 py-1.5 w-16 focus:outline-none focus:ring-1 focus:ring-accent"
                            />
                            <button type="submit" className="bg-accent text-white px-3 py-1.5 rounded-md hover:bg-blue-600 transition-colors text-sm font-medium">Add</button>
                        </form>
                    </div>
                );
            };

            const WIDGET_DEF = {
                'DAX': { title: INDICES['DAX'].name, component: <MarketChart dataKey="DAX" /> },
                'DOW': { title: INDICES['DOW'].name, component: <MarketChart dataKey="DOW" /> },
                'SP500': { title: INDICES['SP500'].name, component: <MarketChart dataKey="SP500" /> },
                'NIKKEI': { title: INDICES['NIKKEI'].name, component: <MarketChart dataKey="NIKKEI" /> },
                'MSCI_CHINA': { title: INDICES['MSCI_CHINA'].name, component: <MarketChart dataKey="MSCI_CHINA" /> },
                'FEAR_GREED': { title: 'Fear & Greed Index', component: <FearGreedWidget /> },
                'PORTFOLIO': { title: 'My Portfolio', component: <PortfolioWidget /> }
            };

            const App = () => {
                const [layout, setLayout] = useState([
                    'DAX', 'DOW', 'SP500', 'NIKKEI', 'MSCI_CHINA', 'FEAR_GREED', 'PORTFOLIO'
                ]);

                const [draggedItem, setDraggedItem] = useState(null);

                useEffect(() => {
                    const savedLayout = localStorage.getItem('apex_layout_real');
                    if (savedLayout) {
                        try {
                            const parsed = JSON.parse(savedLayout);
                            if (parsed.length === layout.length) {
                                setLayout(parsed);
                            }
                        } catch (e) {}
                    }
                }, []);

                const saveLayout = (newLayout) => {
                    setLayout(newLayout);
                    localStorage.setItem('apex_layout_real', JSON.stringify(newLayout));
                };

                const handleDragStart = (e, index) => {
                    setDraggedItem(index);
                    e.dataTransfer.effectAllowed = 'move';
                    setTimeout(() => e.target.classList.add('dragging'), 0);
                };

                const handleDragOver = (e, index) => {
                    e.preventDefault();
                    e.dataTransfer.dropEffect = 'move';
                };

                const handleDragEnter = (e) => {
                    e.preventDefault();
                    const target = e.currentTarget;
                    if (!target.classList.contains('dragging')) {
                        target.classList.add('drag-over');
                    }
                };

                const handleDragLeave = (e) => {
                    e.currentTarget.classList.remove('drag-over');
                };

                const handleDrop = (e, index) => {
                    e.preventDefault();
                    e.currentTarget.classList.remove('drag-over');
                    document.querySelectorAll('.draggable-widget').forEach(el => el.classList.remove('dragging'));
                    
                    if (draggedItem === null || draggedItem === index) return;

                    const newLayout = [...layout];
                    const item = newLayout.splice(draggedItem, 1)[0];
                    newLayout.splice(index, 0, item);
                    
                    saveLayout(newLayout);
                    setDraggedItem(null);
                };

                return (
                    <div className="min-h-screen p-6 md:p-10">
                        <header className="mb-10 flex items-center justify-between col-span-full">
                            <div className="flex items-center space-x-3">
                                <div className="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center transform rotate-12">
                                    <span className="text-white font-bold text-xl block transform -rotate-12">A</span>
                                </div>
                                <h1 className="text-3xl font-bold tracking-tight text-navy">Apex</h1>
                            </div>
                            <div className="text-sm font-medium text-emerald-600 bg-emerald-50 px-4 py-2 rounded-full border border-emerald-200 shadow-sm flex items-center">
                                <div className="w-2 h-2 rounded-full bg-emerald-500 mr-2 animate-pulse"></div>
                                Live Data Sync
                            </div>
                        </header>

                        <main className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 auto-rows-fr">
                            {layout.map((key, index) => {
                                const def = WIDGET_DEF[key];
                                if (!def) return null;
                                const isWide = key === 'PORTFOLIO' || key === 'DAX' || key === 'DOW';
                                return (
                                    <div key={key} className={isWide ? "md:col-span-2" : "col-span-1"}>
                                        <Card 
                                            id={key}
                                            title={def.title}
                                            onDragStart={(e) => handleDragStart(e, index)}
                                            onDragOver={(e) => handleDragOver(e, index)}
                                            onDragEnter={handleDragEnter}
                                            onDragLeave={handleDragLeave}
                                            onDrop={(e) => handleDrop(e, index)}
                                        >
                                            {def.component}
                                        </Card>
                                    </div>
                                );
                            })}
                        </main>
                    </div>
                );
            };

            const root = ReactDOM.createRoot(document.getElementById('root'));
            root.render(<App />);
        } catch(error) {
            console.error(error);
        }
    </script>
</body>
</html>
